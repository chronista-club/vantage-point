graph TD
    subgraph "Application Layer"
        A[VantageApp]
        B[ContentView]
    end

    subgraph "Service Abstraction Layer"
        C[ClaudeServiceProtocol]
    end

    subgraph "Platform Implementation Layer"
        D[ClaudeCodeService<br/>macOS]
        E[ClaudeAPIService<br/>visionOS]
    end

    subgraph "Infrastructure Layer"
        F[Keychain]
        G[Network]
        H[IPC]
    end

    A --> C
    B --> C
    C --> D
    C --> E
    D --> F
    D --> H
    E --> F
    E --> G

    style A fill:#ff9999
    style B fill:#ff9999
    style C fill:#66b3ff
    style D fill:#99ff99
    style E fill:#99ff99
    style F fill:#ffcc99
    style G fill:#ffcc99
    style H fill:#ffcc99